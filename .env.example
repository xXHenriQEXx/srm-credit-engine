# ============================================================
#  SRM Credit Engine — Variáveis de Ambiente
#  Copie este arquivo para .env e ajuste os valores:
#    cp .env.example .env
#
#  O arquivo .env NUNCA deve ser commitado no Git.
#  Este .env.example SIM — ele documenta o contrato de config.
# ============================================================

# ── Banco de Dados ───────────────────────────────────────────
POSTGRES_DB=srm_credit_engine
POSTGRES_USER=srm_user
POSTGRES_PASSWORD=troque_esta_senha

# ── Backend ──────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=srm_credit_engine
DB_USER=srm_user
DB_PASSWORD=troque_esta_senha

# Chave HMAC-SHA para assinatura dos tokens JWT.
# Use no mínimo 32 caracteres aleatórios em produção.
# Gere um valor forte com: openssl rand -hex 32
JWT_SECRET=troque_por_uma_chave_forte_com_32_chars_ou_mais
JWT_EXPIRATION_MINUTES=60
